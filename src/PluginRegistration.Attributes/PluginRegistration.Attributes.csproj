<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <RootNamespace>PluginRegistration.Attributes</RootNamespace>
    <AssemblyName>PluginRegistration.Attributes</AssemblyName>
    <Description>Dataverse / Dynamics 365 plugin registration attributes for use with [CrmPluginRegistration], Custom API, and step images.</Description>

    <!-- Package identity (inherits Version, Authors, Tags etc. from Directory.Build.props) -->
    <PackageId>PluginRegistration.Attributes</PackageId>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IsPackable>true</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" Visible="false" />
  </ItemGroup>

</Project>